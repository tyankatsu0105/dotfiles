// Place your key bindings in this file to override the defaults
[
  {
    "key": "cmd+y",
    "command": "redo"
  },
  {
    "key": "shift+cmd+z",
    "command": "-redo"
  },
  {
    "key": "cmd+enter",
    "command": "workbench.action.chat.submit",
    "when": "inChatInput && chatInputHasText"
  },
  {
    "key": "enter",
    "command": "type",
    "args": {
      "text": "\n"
    },
    "when": "inChatInput"
  }
]
