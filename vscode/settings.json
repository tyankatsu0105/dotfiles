  "gitlens.ai.model": "vscode",
  "gitlens.ai.vscode.model": "copilot:gpt-5.3-codex",
  "rubyLsp.rubyExecutablePath": "/lincwell/packs/clinic_rest_api/app/serializers/components/user_orca_patient_serializer.rb",
  "gitlens.ai.gitkraken.model": "gemini:gemini-2.0-flash",
