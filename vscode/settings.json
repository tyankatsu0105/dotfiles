  "roo-cline.allowedCommands": [
    "git log",
    "git show",
    "npm run",
    "cp",
    "mv",
    "git branch",
    "git fetch",
    "git diff",
    "mkdir",
    "grep",
    "sed",
    "sleep",
    "wc",
    "cd",
    "cat",
    "git diff preview",
    "gh pr",
    "gh api",
    "git commit",
    "which",
    "echo",
    "ls",
    "find",
    "chmod",
    "docker compose",
    "make",
    "bash",
    "perl",
    "open",
    "git status"
